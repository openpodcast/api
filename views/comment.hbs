<!DOCTYPE html>
<html>
<head>
    <title>Thank you for your comment!</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f5f7fb;
            color: #1f2937;
            font-family: Arial, Helvetica, sans-serif;
        }

        .container {
            width: 100vw;
            min-height: 100vh;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .feedback {
            width: min(100%, 500px);
            background-color: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            padding: 28px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
        }

        .feedback img {
            width: 56px;
            height: 56px;
        }

        .feedback h1 {
            font-size: 1.75rem;
            line-height: 1.2;
            margin: 0;
            text-align: center;
        }

        .feedback p {
            font-size: 1rem;
            line-height: 1.5;
            margin: 0;
            text-align: center;
            color: #4b5563;
        }

        @media (max-width: 480px) {
            .container {
                padding: 16px;
            }

            .feedback {
                padding: 22px;
            }

            .feedback h1 {
                font-size: 1.45rem;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="feedback">
            <img src="/images/checkmark.svg" alt="checkmark">
            <h1>Thank you for your comment!</h1>
            <p>
                We appreciate that you took the time to submit a comment.
                Your comment will be reviewed and considered for future episodes!
            </p>
            <p>You can close this window now.</p>
        </div>
    </div>
</body>
</html>

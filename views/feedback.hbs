<!DOCTYPE html>
<html>
<head>
    <title>Thank you for your feedback!</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f5f7fb;
            color: #1f2937;
            font-family: Arial, Helvetica, sans-serif;
        }

        .wrapper {
            width: 100vw;
            min-height: 100vh;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: min(100%, 520px);
        }

        .feedback {
            background-color: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            padding: 28px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .feedback img {
            width: 56px;
            height: 56px;
            align-self: center;
        }

        .feedback h1 {
            font-size: 1.75rem;
            line-height: 1.2;
            margin: 0;
            text-align: center;
        }

        .feedback p {
            font-size: 1rem;
            line-height: 1.5;
            margin: 0;
            text-align: center;
            color: #4b5563;
        }

        .feedback form {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 6px;
        }

        label {
            font-weight: 700;
            font-size: 0.92rem;
        }

        .feedback form input,
        .feedback form textarea {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            padding: 12px;
            font: inherit;
            color: #111827;
            background: #fff;
        }

        .feedback form input:focus,
        .feedback form textarea:focus {
            border-color: #2563eb;
            outline: 3px solid rgba(37, 99, 235, 0.16);
        }

        .feedback form textarea {
            min-height: 132px;
            resize: vertical;
        }

        .form-error {
            border: 1px solid #fecaca;
            border-radius: 6px;
            padding: 12px;
            background: #fef2f2;
            color: #991b1b;
            text-align: left;
            font-size: 0.95rem;
        }

        .feedback form button,
        .close {
            border: none;
            border-radius: 6px;
            color: #fff;
            font: inherit;
            font-weight: 700;
            cursor: pointer;
            transition: background-color 120ms ease, transform 120ms ease;
        }

        .feedback form button {
            min-height: 46px;
            background-color: #2563eb;
        }

        .feedback form button:hover,
        .close:hover {
            transform: translateY(-1px);
        }

        .close-wrapper {
            margin-top: 12px;
            width: 100%;
        }

        .close {
            width: 100%;
            min-height: 48px;
            background-color: #475569;
        }

        @media (max-width: 480px) {
            .wrapper {
                padding: 16px;
            }

            .feedback {
                padding: 22px;
            }

            .feedback h1 {
                font-size: 1.45rem;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">
            <div class="feedback">
                <img src="/images/checkmark.svg" alt="checkmark">
                <h1>Thank you for your feedback!</h1>
                <p>Thank you for helping us improve our podcast.</p>
                <p>Feel free to send us additional feedback using the form below.</p>
                {{#if numberOfComments}}
                    <p>So far we received {{numberOfComments}} comment(s) for this episode.</p>
                {{/if}}
                <form action="/comments/{{episodeId}}" method="post">
                    {{#if formError}}
                        <div class="form-error" role="alert">{{formError}}</div>
                    {{/if}}
                    <label for="email">Email (optional)</label>
                    <input id="email" type="email" name="email" value="{{values.email}}" autocomplete="email" placeholder="you@example.com">
                    <label for="comment">Comment</label>
                    <textarea id="comment" name="comment" minlength="3" maxlength="1000" required placeholder="Speak your mind!">{{values.comment}}</textarea>
                    <button type="submit">Send comment</button>
                </form>
            </div>
            <div class="close-wrapper">
                <button class="close" onclick="window.history.back()">Close</button>
            </div>
        </div>
    </div>
</body>
</html>
